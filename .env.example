# ===================================================
# Nexa NFT Marketplace - Environment Variables
# ===================================================
# Copy this to .env.local and fill in the real values.
# NEVER commit .env.local to git!

# ------ Pinata IPFS (for NFT uploads) ------
# Get this from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_here

# ------ WalletConnect (for wallet modal) ------
# Get this from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id_here
